# Database
DATABASE_URL="postgresql://username:password@localhost:5432/kinsen_helpdesk"

# Auth.js Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Azure AD)
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-client-secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"
AZURE_AD_TENANT_ID="your-azure-tenant-id"

# Microsoft Graph API (for email integration)
GRAPH_CLIENT_ID="your-graph-client-id"
GRAPH_CLIENT_SECRET="your-graph-client-secret"
GRAPH_TENANT_ID="your-graph-tenant-id"
GRAPH_USER_EMAIL="kinsenitsupport@kinsen.gr"

# File Upload (local storage path)
UPLOAD_DIR="./public/uploads"
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_EMAIL_DOMAIN="kinsen.gr"
SUPPORT_EMAIL="kinsenitsupport@kinsen.gr"
